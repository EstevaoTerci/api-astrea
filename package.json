{
  "name": "api-astrea",
  "version": "1.0.0",
  "description": "API de scraping stateless para o sistema jurídico Astrea",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "mcp": "tsx src/mcp/mcp-server.ts",
    "mcp:build": "tsc && node dist/mcp/mcp-server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/nodemailer": "^7.0.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "nodemailer": "^8.0.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "playwright": "1.58.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
