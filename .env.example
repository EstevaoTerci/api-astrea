# ─────────────────────────────────────────────────────────────────────
# Credenciais do Astrea (https://astrea.net.br)
# ─────────────────────────────────────────────────────────────────────
ASTREA_EMAIL=seu@email.com
ASTREA_PASSWORD=sua_senha_aqui

# ─────────────────────────────────────────────────────────────────────
# Autenticação da API (gere uma chave segura com: openssl rand -hex 32)
# ─────────────────────────────────────────────────────────────────────
API_KEY=gere_uma_chave_segura_aqui_com_pelo_menos_32_chars

# ─────────────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────
# Pool de Browsers (Playwright)
# ─────────────────────────────────────────────────────────────────────
# Número de contextos simultâneos (1-10). Cada contexto usa ~80-150MB RAM.
BROWSER_POOL_SIZE=5

# Timeout em ms para operações do browser e para aguardar context disponível
BROWSER_TIMEOUT_MS=30000

# false = abre janela do browser (útil para debug local)
BROWSER_HEADLESS=true

# Reutiliza a sessão do Astrea entre requisições (evita login repetido)
SESSION_REUSE=true

# ─────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────
# Janela de tempo em ms (padrão: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requisições por IP por janela
RATE_LIMIT_MAX_REQUESTS=30

# ─────────────────────────────────────────────────────────────────────
# Fila de Requisições (RequestQueue)
# ─────────────────────────────────────────────────────────────────────
# Tamanho máximo da fila de espera (rejeita com 503 quando cheia)
QUEUE_MAX_SIZE=20

# Timeout em ms para espera na fila (padrão: 60000 = 1 minuto)
QUEUE_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────────────
# Tenant do Astrea (necessário para chamadas GCP Endpoints / users API)
# ─────────────────────────────────────────────────────────────────────
ASTREA_TENANT_ID=6692712561442816

# ─────────────────────────────────────────────────────────────────────
# LLM Fallback — auto-recuperação de scraping
# Configure ao menos uma chave. O provedor é detectado automaticamente
# pela presença da chave, ou forçado com LLM_PROVIDER.
# ─────────────────────────────────────────────────────────────────────

# Anthropic (Claude Haiku — recomendado)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o-mini)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google (Gemini 1.5 Flash)
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-flash

# Força um provedor específico (opcional): anthropic | openai | google
# LLM_PROVIDER=anthropic

# ─────────────────────────────────────────────────────────────────────
# Notificação de incidentes por email (SMTP)
# ─────────────────────────────────────────────────────────────────────
DEVELOPER_EMAIL=estevaoterci@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=email@gmail.com
# SMTP_PASS=app-password-do-gmail
